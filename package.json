{
  "name": "phosphor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint --ext .js,.vue src"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "core-js": "^3.49.0",
    "pinia": "^3.0.4",
    "random-seed": "^0.3.0",
    "random-word-slugs": "^0.1.7",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/plugin-transform-private-methods": "^7.28.6",
    "@babel/plugin-transform-private-property-in-object": "^7.28.6",
    "@vitejs/plugin-vue": "^6.0.6",
    "buffer": "^6.0.3",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
    "vite": "^8.0.10",
    "vite-plugin-node-polyfills": "^0.26.0"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "rules": {
      "no-debugger": "off"
    },
    "ignorePatterns": [
      "src/play/*"
    ]
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
